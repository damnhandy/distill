{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.13.7/.schema/devbox.schema.json",
  "packages": [
    "go@latest",
    "buildah@latest",
    "podman@latest",
    "skopeo@latest",
    "container-structure-test@latest",
    "cosign@latest",
    "grype@latest",
    "syft@latest",
    "oras@latest",
    "slsa-verifier@latest",
    "jq@latest",
    "yq-go@latest",
    "gitversion@latest"
  ],
  "env": {
    "GOPATH": "$HOME/go",
    "GOBIN": "$HOME/go/bin"
  },
  "shell": {
    "init_hook": [
      "echo 'distill dev environment ready'",
      "echo ''",
      "echo '  go build -o distill .   — build the CLI'",
      "echo '  devbox run --list       — see available scripts'"
    ],
    "scripts": {
      "build-cli": [
        "# Build the distill CLI binary.",
        "go build -o distill .",
        "echo 'Built ./distill'"
      ],
      "install-cli": [
        "# Install the distill CLI to $GOBIN.",
        "go install .",
        "echo 'Installed distill to $GOBIN'"
      ],
      "test": [
        "# Usage: devbox run test <image:tag> <test-config.yaml>",
        "# Runs container-structure-test against a built image.",
        "container-structure-test test \\",
        "  --image \"${1:?Usage: devbox run test <image:tag> <config.yaml>}\" \\",
        "  --config \"${2:?missing test config}\""
      ],
      "scan": [
        "# Usage: devbox run scan <image:tag>",
        "# Scans an image for CVEs and fails on any CRITICAL findings.",
        "grype \"${1:?Usage: devbox run scan <image:tag>}\" --fail-on critical"
      ],
      "sbom": [
        "# Usage: devbox run sbom <image:tag> [output-file]",
        "# Generates an SPDX SBOM for an image.",
        "IMAGE=${1:?Usage: devbox run sbom <image:tag> [output-file]}",
        "OUT=${2:-sbom.spdx.json}",
        "syft \"${IMAGE}\" -o spdx-json > \"${OUT}\"",
        "echo \"SBOM written to ${OUT}\""
      ],
      "sign": [
        "# Usage: devbox run sign <image@digest>",
        "# Signs an image using keyless Sigstore. Set COSIGN_KEY for key-based signing.",
        "IMAGE=${1:?Usage: devbox run sign <image@digest>}",
        "if [ -n \"${COSIGN_KEY:-}\" ]; then",
        "  cosign sign --key \"${COSIGN_KEY}\" \"${IMAGE}\"",
        "else",
        "  cosign sign \"${IMAGE}\"",
        "fi"
      ],
      "inspect": [
        "# Usage: devbox run inspect <image:tag>",
        "# Shows image config and layer summary.",
        "skopeo inspect --config \"docker://${1:?Usage: devbox run inspect <image:tag>}\" | jq .",
        "echo ''",
        "skopeo inspect \"docker://${1}\" | jq '{Digest, Layers: (.Layers | length), Created, Labels, Env}'"
      ],
      "verify-slsa": [
        "# Usage: devbox run verify-slsa <image:tag> <provenance-file>",
        "# Verifies SLSA provenance for a published artifact.",
        "slsa-verifier verify-image \\",
        "  \"${1:?Usage: devbox run verify-slsa <image:tag> <provenance>}\" \\",
        "  --provenance-path \"${2:?missing provenance file}\" \\",
        "  --source-uri \"github.com/damnhandy/distill\""
      ]
    }
  }
}
